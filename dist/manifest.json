{
  "manifest_version": 3,
  "name": "SideFlow",
  "description": "The Universal Productivity Communication Sidebar — access all your apps without switching tabs.",
  "version": "1.0.0",
  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "32": "public/icons/icon32.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "commands",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "public/rules.json"
      }
    ]
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space"
      },
      "description": "Toggle SideFlow sidebar"
    },
    "switch-app-1": {
      "suggested_key": {
        "default": "Alt+1"
      },
      "description": "Switch to app slot 1"
    },
    "switch-app-2": {
      "suggested_key": {
        "default": "Alt+2"
      },
      "description": "Switch to app slot 2"
    },
    "toggle-command-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+K"
      },
      "description": "Open command palette"
    }
  }
}
